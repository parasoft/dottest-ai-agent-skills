# =============================================================================
# dottest-analyzer.config  —  Optional configuration file for the dotTEST Analyzer skill
#
# Pass the path to this file via the DOTTEST_ANALYZER_CONFIG environment variable:
#
#   Windows (PowerShell):  $env:DOTTEST_ANALYZER_CONFIG = "C:\path\to\dottest-analyzer.config"
#
# Format rules:
#   - One key=value pair per line
#   - Lines starting with # are treated as comments and ignored
#   - Blank lines are ignored
#   - Keys must exactly match the environment variable names listed below
#   - Values must NOT be quoted (no surrounding " or ' characters)
#   - Values defined here are loaded BEFORE environment variables are read,
#     so an environment variable always overrides the same key in this file
# =============================================================================

# -----------------------------------------------------------------------------
# Required settings
# -----------------------------------------------------------------------------

# Path to the dotTEST installation directory.
# Windows example: DOTTEST_HOME=C:\Program Files\Parasoft\dotTEST\2026.1
# Linux/macOS example: DOTTEST_HOME=/opt/parasoft/dottest
#DOTTEST_HOME=C:\Program Files\Parasoft\dotTEST\2026.1

# Absolute path to the .NET project solution file to analyse.
# Windows example: SOLUTION_PATH=C:\projects\myapp\myapp.sln
#SOLUTION_PATH=C:\Users\jzielnik\Documents\Parasoft\dotTEST 10\Examples2025.2.0\NET Framework\VS2022\SourceCode\BankExample\BankExampleWithTests.sln

# -----------------------------------------------------------------------------
# Optional settings
# -----------------------------------------------------------------------------

# Absolute path to the directory where output will be stored. 
# If not set, defaults to the current execution directory.
# Example: OUTPUT_DIR=C:/dottest_output
#OUTPUT_DIR=

# Test configuration to use for static analysis.
# Defaults to: builtin://Recommended Rules
# Other examples: builtin://Find Duplicated Code, builtin://Security Rules
#DOTTEST_TEST_CONFIGURATION=builtin://Recommended Rules

# Set to true to commit each successful fix as a Git commit.
# Any other value (or absence) leaves fixes as local uncommitted changes.
# Defaults to: false
#DOTTEST_COMMIT_FIXES=false

# Comma-separated list of rule IDs to process. When set, only violations
# matching these IDs are fixed. Leave unset to process all violations.
# Example: DOTTEST_FILTER_RULE=BD.PB.CC,SEC.VPPD
#DOTTEST_FILTER_RULE=

# Absolute path to a dotTEST settings file (.properties).
# When set, adds -settings=<path> to all analysis commands.
#DOTTEST_SETTINGS=

# Absolute path to a base static analysis report.xml file. When set and its test 
# configuration matches DOTTEST_TEST_CONFIGURATION, Step 3 is skipped (uses existing baseline).
#DOTTEST_BASE_STATIC_ANALYSIS_REPORT=

# Set to true to skip unit test execution in Step 2 (only build check) and 
# Step 7.1 (fix verification). Useful when unit tests are slow or unavailable.
# Defaults to: false
#DISABLE_UNIT_TEST_VERIFICATION=false

# Absolute path to a base unit test report.xml file. When both this and 
# DOTTEST_BASE_UNIT_TEST_COVERAGE are set, Step 2 only verifies the build (no test run),
# and Step 7.1 uses Test Impact Analysis (TIA). When not set, Step 2 runs tests with 
# coverage to create the baseline.
#DOTTEST_BASE_UNIT_TEST_REPORT=

# Absolute path to a base unit test coverage.xml file. When both this and 
# DOTTEST_BASE_UNIT_TEST_REPORT are set, Step 2 only verifies the build (no test run),
# and Step 7.1 uses Test Impact Analysis (TIA). When not set, Step 2 runs tests with 
# coverage to create the baseline.
#DOTTEST_BASE_UNIT_TEST_COVERAGE=

# Name of the branch where fixes are committed. When set, used as the target branch 
# for committing fixes. If not set, the default value parasoft-ai-fixes-[timestamp] is used.
# Example: FIXES_BRANCH_NAME=feature/ai-fixes
#FIXES_BRANCH_NAME=

# Number of additional attempts to fix the particular violation when verification unit test run has failed or despite fix new violation emerges.
# If corresponding subskill for test fix is invoked the first attempt to fix a test is always invoked.
# This setting indicate how much additional tries should be made to fix the violation.
#DOTTEST_FIX_ATTEMPTS=1

# This setting introduce a limit for the number of violations that should be fixed during running session.
# If this setting is not set, it will be defaulted to 5 fixes.
#DOTTEST_STATIC_NO_OF_MAX_FIXES=5

# Name of the branch which is used as a reference branch. Only differences between current branch and the target branch will be analyzed
#DOTTEST_REFERENCE_BRANCH=main